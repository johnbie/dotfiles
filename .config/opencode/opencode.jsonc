        "google/gemma-4-12b-qat": { "name": "Gemma 4 12B QAT (local)" },
        "ornith-1.0-9b": { "name": "Ornith 1.0 9B (local)" },
        "vibethinker-3b": { "name": "VibeThinker 3B (local)" },
        "diffusiongemma-26b-a4b-it": { "name": "DiffusionGemma 26B A4B IT (local)" }
      }
    }
  }
}

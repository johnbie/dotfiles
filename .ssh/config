# Managed by ~/dotfiles (.ssh/config -> stowed/symlinked into ~/.ssh/config).
# AddKeysToAgent loads a key into the running agent the first time it's used,
# so an interactive session prompts for the passphrase at most once per agent
# lifetime — no manual `ssh-add` needed. The persistent agent is set up by
# autoload/load_ssh_agent.sh (~/.ssh/agent.env).

Host *
  AddKeysToAgent yes

Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519
